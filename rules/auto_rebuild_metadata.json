{
  "protocol_name": "Auto-Rebuild Metadata",
  "description": "Automatic metadata update mechanisms for the wiki. Agent triggers rebuilds after any wiki edit.",
  "rebuild_paths": {
    "full": "./scripts/rebuild-meta.sh",
    "index_only": "./scripts/rebuild-meta.sh --index-only"
  },
  "trigger_by_process": {
    "ingest": "After create_page → full rebuild (step_3a)",
    "query": "Post-checks: rebuild-meta + link-validator.sh",
    "lint": "After link_validation → index-only rebuild"
  },
  "schema_ref_to_agent_rules": "AGENTS.md#rules-reference"
}
