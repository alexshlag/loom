{
  "rule_name": "session_context_management",
  "rule_id": "SCM-V1",

  "memory_layers": {
    "working_memory.json": {"lifecycle": "turn → turn"},
    "hot.md": {"lifecycle": "inter-session, updated on every important action"},
    "log.md": {"lifecycle": "append-only"}
  },

  "save_triggers": [
    {"trigger_id": "user_message_received",        "rule_id": "HOT-SAVE-QUERY-V1",         "fields": ["query_intent", "project_context", "timestamp"]},
    {"trigger_id": "action_completed",              "rule_id": "HOT-SAVE-ACTION-V1",        "fields": ["action_summary", "wiki_pages_used", "key_findings"]},
    {"trigger_id": "wiki_page_modified",            "rule_id": "HOT-WIKI-CHANGES-V1",       "fields": ["pages_modified", "changes_summary", "sources_added"]},
    {"trigger_id": "page_created_or_updated",       "rule_id": "WM-SYNC-AFTER-WIKI-V1",     "fields": ["focus_node", "next_steps_todo (auto-cleanup)", "query_summary"]}
  ],

  "write_algorithm": {
    "step_1_capture_user_query":   {"rule_id": "HOT-SAVE-QUERY-V1",         "hot_section": "Active Session Context → topic, query_intent"},
    "step_2_update_after_action":  {"rule_id": "HOT-SAVE-ACTION-V1",        "hot_section": "Active Session Context → pages read, key findings"},
    "step_3_wiki_page_modified":   {"rule_id": "HOT-WIKI-CHANGES-V1",       "hot_section": "System State → Recent Changes section", "priority": "immediate"},
    "step_4_working_memory_sync":  {"rule_id": "WM-SYNC-AFTER-WIKI-V1",     "hot_section": "System State → Recent Changes section", "priority": "immediate"}
  },

  "read_algorithm": {
    "session_start":           {"rule_id": "HOT-LOAD-V1",         "steps": [{"step": 1, "action": "read working_memory.json"}, {"step": 2, "action": "restore-hot-cache.sh read Active Project + Session Context"}]},
    "log_context_reading":     {"rule_id": "HOT-LOG-READ-V1",     "pattern": "grep -m 20 '' wiki/log.md | tail -20 (NEVER cat)"}
  },

  "constraints": [
    "NEVER wait until session end to write hot.md — write immediately after action",
    "NEVER duplicate log.md content in hot.md — only summary slice",
    "NEVER append to JSON files — read entire file → modify → write complete document"
  ],

  "golden_rules": [
    {"rule_id": "IMMEDIATE_WRITE",       "value": "Write hot.md immediately, not at session end"},
    {"rule_id": "SLICE_NOT_FULL_LOG",    "value": "hot.md = summary slice, never full log copy"},
    {"rule_id": "RESTORE_ON_COMPACT",    "value": "restore-hot-cache.sh restores hot.md after compact"},
    {"rule_id": "SYSTEM_STATE_ALWAYS",   "value": "System State section updated on every wiki create/update"}
  ]
}
