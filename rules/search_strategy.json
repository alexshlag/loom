{
  "rule_name": "search_and_discovery",
  "rule_id": "SD-V2",
  "version": "2.0 (extracted from AGENTS.md, 2026-07-05)",
  "description": "Search strategy: primary tool, fallback chain, query intent analysis, relevance scoring algorithm",
  "primary_tool": {
    "command": "./scripts/wiki-search.sh --dynamic \"<query>\"",
    "purpose": "Analyzes intent, category priority, relevance scoring"
  },
  "fallback_chain": [
    {
      "step": 1,
      "pattern": "grep -m 30 \"<keyword>\" wiki/index.md",
      "condition": "if >=2 matches -> use"
    },
    {
      "step": 2,
      "pattern": "grep -m 20 \"<keyword>\" meta/search-index.json"
    }
  ],
  "constraints": {
    "prohibited_tools": [
      "find",
      "ls",
      "cat"
    ],
    "rule": "only wiki-search.sh --dynamic first for search"
  },
  "if_broken": {
    "action": "STOP_SEARCH -> ./scripts/wiki-search.sh --dynamic <query>",
    "description": "If search fails, stop and retry with dynamic mode"
  },
  "relevance_scoring": {
    "tool": "./scripts/wiki-search.sh --dynamic \"query\"",
    "description": "Dynamic category order based on query intent, results sorted by combined score descending"
  },
  "intent_analysis": [
    {
      "keywords": "entity keywords",
      "priority_order": [
        "entities/",
        "concepts/",
        "syntheses/"
      ]
    },
    {
      "keywords": "comparison (vs, compared to)",
      "priority_order": [
        "comparisons/",
        "syntheses/",
        "concepts/"
      ]
    },
    {
      "keywords": "concept keywords",
      "priority_order": [
        "concepts/",
        "syntheses/",
        "entities/"
      ]
    },
    {
      "fallback": "static priority",
      "order": [
        "syntheses/",
        "concepts/",
        "entities/"
      ]
    }
  ],
  "scoring_weights": [
    {
      "factor": "position_weight",
      "rule": "query in H1 = +3, body = +1 per occurrence"
    },
    {
      "factor": "frequency_weight",
      "rule": "total occurrences x 1"
    },
    {
      "factor": "backlink_weight",
      "rule": "mentions in other wiki pages x 5"
    },
    {
      "factor": "category_bonus",
      "rule": "earlier priority category gets +10x(max_priority - index)"
    }
  ],
  "scoring_thresholds": [
    {
      "score_min": 5,
      "action": "Strong candidate - suggest crosslink with confidence"
    },
    {
      "score_range": "3-4",
      "action": "Weak signal - suggest review, agent decides"
    },
    {
      "score_max": 2,
      "action": "Ignore (below noise floor)"
    }
  ],
  "schema_ref_to_agent_rules": "AGENTS.md#search--discovery"
}
