{
  "protocol_name": "Wiki Operation Routing Contract",
  "description": "All wiki create/update operations MUST go through process-ingest.json or process-query.json steps. Never direct edit() without process flow.",
  "schema_ref_to_agent_rules": "AGENTS.md#wiki-operation-routing-contract",

  "core_rule": {
    "rule": "all_wiki_create_update_operations_must_go_through_process_files",
    "prohibition": "never_direct_edit_without_process_flow"
  },

  "routing_table": [
    {
      "scenario": "web_search_update_existing_page",
      "process_file": "process-query.json#web_ingest_flow → process-ingest.json",
      "transition_trigger": "existing_page_identified_from_web_data",
      "user_confirm": false,
      "auto_mode": true
    },
    {
      "scenario": "web_search_topic_expansion",
      "process_file": "process-query.json#web_ingest_flow → process-ingest.json",
      "transition_trigger": "new_subtopic_of_existing_topic",
      "user_confirm": false,
      "auto_mode": true,
      "note": "No user confirmation required — create new wiki page + links to existing topic"
    },
    {
      "scenario": "web_search_new_independent_topic",
      "process_file": "process-query.json#web_ingest_flow → process-ingest.json",
      "transition_trigger": "new_independent_topic_not_in_wiki",
      "user_confirm": true,
      "auto_mode": false,
      "note": "Required only for first page of this topic"
    },
    {
      "scenario": "update_existing_page_with_new_facts",
      "process_file": "process-ingest.json#step_8b_update_page",
      "transition_trigger": "source_identifies_existing_page",
      "user_confirm": false,
      "auto_mode": true
    },
    {
      "scenario": "simple_query_answer_no_save",
      "process_file": "process-query.json only",
      "transition_trigger": "no_compounding_flag",
      "user_confirm": null,
      "auto_mode": true,
      "note": "N/A — no save operation"
    }
  ],

  "ingress_points_from_lint": {
    "trigger": "new_sources_detected",
    "action": "web_ingest_flow.trigger",
    "schema_ref_process_file": "process-query.json#web_ingest_flow"
  },

  "ingress_points_from_query": {
    "trigger": "topic_expansion_detected",
    "action": "TRANSITION_TO process-ingest.json via web_ingest_flow (create_new_expansion_of_existing, auto)"
  }
}
