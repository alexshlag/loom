{
  "protocol_name": "Wiki Operation Routing Contract",
  "description": "All wiki create/update operations MUST go through process-ingest.json or process-query.json steps. Never direct edit() without process flow.",
  "schema_ref_to_agent_rules": "rules/external_sources_policy.json",

  "core_rule": {
    "rule": "all_wiki_create_update_operations_must_go_through_process_files",
    "prohibition": "never_direct_edit_without_process_flow"
  },

  "routing_table": [
    {"scenario": "web_search_update_existing_page", "transition": "existing_page_identified_from_web_data → auto_ingest", "user_confirm": false, "auto_mode": true},
    {"scenario": "web_search_topic_expansion", "transition": "new_subtopic_of_existing_topic → auto_ingest", "user_confirm": false, "auto_mode": true},
    {"scenario": "web_search_new_independent_topic", "transition": "new_independent_topic_not_in_wiki → propose_to_user", "user_confirm": true, "auto_mode": false},
    {"scenario": "update_existing_page_with_new_facts", "transition": "source_identifies_existing_page → process-ingest.json#step_8b_update_page", "user_confirm": false, "auto_mode": true},
    {"scenario": "simple_query_answer_no_save", "transition": "no_compounding_flag → no save", "user_confirm": null, "auto_mode": true}
  ],

  "schema_ref_to_agent_rules": "rules/external_sources_policy.json"
}
