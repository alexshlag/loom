{
  "name": "session-bootstrap",
  "trigger": "session_start",
  "description": "Order-independent, explicit file load sequence for session start. Agent MUST execute all steps in order.",
  "steps": [
    {
      "order": 1,
      "action": "read_file",
      "path": "working_memory.json"
    },
    {
      "order": 2,
      "action": "read_file",
      "path": "wiki/hot.md"
    },
    {"order": 3, "action": "read_file", "path": "rules/git_conventions.json"},
    {"order": 4, "action": "read_file", "path": "wiki/docs-existence-check.json"},
    {"order": 5, "action": "scan_directory", "path": "wiki/skills/", "output": "working_memory.skills_loaded = [{name, category}]", "note": "Non-blocking — filter results by tags containing 'skill'", "schema_ref": "rules/skill_format.json#category_taxonomy"}
  ]
}
