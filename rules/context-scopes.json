{
  "version": "2.0",
  "policy": {
    "all_transient": true,
    "auto_read_source": "AGENTS.md (via agent_read_instructions in process files)"
  },
  "fresh_rules": [
    {
      "id": "MEMORY_CONTRACT",
      "schema_ref": "rules/session_context_rules.json"
    },
    {
      "id": "EXECUTION_CONTRACT",
      "schema_ref": "rules/execution_contract.json"
    },
    {
      "id": "ERROR_HANDLING",
      "schema_ref": "rules/error_handling.json"
    },
    {
      "id": "GIT_CONVENTIONS",
      "schema_ref": "rules/git_conventions.json"
    },
    {
      "id": "PROTECTED_ZONES",
      "schema_ref": "rules/protected_zones.json"
    },
    {
      "id": "SILENT_OUTPUT",
      "schema_ref": "rules/execution_modes.json"
    },
    {
      "id": "EXECUTION_MODES",
      "schema_ref": "rules/execution_modes.json"
    },
    {
      "id": "NATURAL_MEMORY",
      "schema_ref": "rules/session_context_rules.json#operational_rules.natural_memory_translation"
    },
    {
      "id": "LOG_APPEND_ONLY",
      "schema_ref": "rules/session_context_rules.json#constraints.LOG_APPEND_ONLY"
    }
  ],
  "hybrid_rules_read_on_demand": [
    {
      "id": "PAGE_TEMPLATES",
      "read_when": "creating/updating pages"
    },
    {
      "id": "LINK_CONVENTIONS",
      "source": "process-ingest.json#external_source_policy"
    },
    {
      "id": "CROSSLINK_DISCOVERY",
      "read_when": "building crosslinks"
    },
    {
      "id": "ADVISORY_LOCKING",
      "source": "scripts/wiki-lock.sh"
    }
  ],
  "process_transient": [
    {
      "id": "INGEST_SPECIFICS",
      "source": "process-ingest.json"
    },
    {
      "id": "QUERY_SPECIFICS",
      "source": "process-query.json"
    },
    {
      "id": "LINT_SPECIFICS",
      "source": "process-lint.json"
    }
  ],
  "schema_ref_to_agent_rules": "rules/context-scopes.json"
}
