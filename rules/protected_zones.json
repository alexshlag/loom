{
  "protected_zones": {
    "meta/**": {
      "access": "scripts_only",
      "owner": "system",
      "rebuild_command": "./scripts/rebuild-meta.sh",
      "files": ["registry.json", "backlinks.json"]
    },
    "raw/**": {
      "access": "read-only",
      "owner": "user"
    },
    "raw/corrected/": {
      "access": "read-write",
      "owner": "agent",
      "tools": ["scripts/raw-correct.sh"]
    },
    "tracking/": {
      "access": "read-write",
      "owner": "agent"
    },
    "wiki/**": {
      "access": "full_manage",
      "owner": "agent"
    }
  },
  "implications": "Agent manages wiki and corrected/ tracking/. User controls raw/."
}