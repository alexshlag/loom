{
  "rule_id": "GIT-CONVENTIONS-V1",
  "commit_format": {
    "pattern": "<type> | <scope>: <description>",
    "types": [
      "feat",
      "fix",
      "refactor",
      "schema",
      "lint",
      "ingest",
      "query"
    ],
    "constraints": {
      "scope": "lowercase component/module name",
      "description": "lowercase imperative summary"
    }
  },
  "staging_by_mode": {
    "wiki": [
      "git add wiki/"
    ],
    "dev_mode": [
      "git add -A"
    ]
  },
  "mode_detection": {
    "auto": "only wiki/*.md → wiki; any .sh/.json in root/rules/scripts/ → dev_mode",
    "override": "user says 'wiki mode' or 'dev_mode'"
  },
  "pre_commit_workflow": [
    {"step": 0, "action": "memory_sync", "schema_ref": "rules/session_context_rules.json#write_triggers.process_complete", "mandatory": true},
    {
      "step": 1,
      "action": "git status --short"
    },
    {"step": 2, "action": "detect staging mode (see mode_detection)"},
    {
      "step": 3,
      "action": "stage with correct command from staging_by_mode"
    },
    {
      "step": 4,
      "action": "git status --short — verify no untracked/unstaged remain"
    },
    {
      "step": 5,
      "prohibited": [
        "git add *",
        "git commit -a"
      ]
    }
  ],
  "post_commit_check": {
    "action": "if git status shows unstaged files → stage + amend or separate commit"
  },
  "schema_ref_to_agent_rules": "AGENTS.md#git-conventions"
}
