{
  "protocol_name": "Non-blocking Lint",
  "entry_points": {
    "standalone": "./scripts/lint.sh [--quiet] [--skip-checks ID1,ID2] — manual or cron",
    "process_lint": "Instead of inline lint → call ./scripts/lint.sh --quiet"
  },
  "output_format": {
    "stdout": "JSON report (machine-parseable)",
    "stderr": "Human-readable summary"
  },
  "checks_table": [
    {"id": 1, "name": "Contradictions (soft)", "action": "grep -m 10 '## Updated \\[.*\\]'"},
    {"id": 2, "name": "Orphan pages", "action": "orphan-pages.sh"},
    {"id": 3, "name": "Knowledge gaps", "action": "— (agent review required)"},
    {"id": 4, "name": "New sources available", "action": "check-new-sources.sh --max 10"},
    {"id": 5, "name": "New topics proposal", "action": "— (requires external sources)"},
    {"id": 6, "name": "Mechanical linting", "action": "duplicate-titles.sh + frontmatter checks"},
    {"id": 7, "name": "Date consistency", "action": "date-consistency.sh"},
    {"id": 8, "name": "Broken links auto-resolve", "action": "unified-pass.sh --auto"},
    {"id": 9, "name": "Contradictions deep scan", "action": "detect-contradications.sh"},
    {"id": 10, "name": "Text similarity scan", "action": "text-similarity.sh --scan-all"},
    {"id": 11, "name": "Hot cache stale check", "action": "check-wiki-changes.sh"}
  ],
  "usage_rules": {
    "agent_call_mode": "Use --quiet for JSON-only output. Never block agent turn.",
    "skip_checks": "Use --skip-checks ID1,ID2 to skip specific checks (e.g., 3,5)",
    "cron_safety": "Safe for cron: 0 */4 * * * cd /path/to/loomana && ./scripts/lint.sh --quiet >> logs/lint.log 2>&1"
  },
  "schema_ref_to_agent_rules": "AGENTS.md#rules-reference"
}
