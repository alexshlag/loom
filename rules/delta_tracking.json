{
  "protocol_name": "Delta Tracking",
  "description": "Hash-based deduplication to prevent re-ingest of already processed sources.",

  "canonical_source": {
    "script":      "scripts/rebuild-source-manifest.sh",
    "manifest_file": "meta/source-manifest.json"
  },

  "steps": [
    {"step_id": "0_delta_check", "action": "./scripts/rebuild-source-manifest.sh --scan-only"},
    {"when": "source_status == processed", "action": "SKIP_INGEST — proceed to Step 2 (discussion)"},
    {"when": "source_status == unprocessed OR stale", "action": "PROCEED_TO_ANALYSIS"}
  ],

  "manifest_structure": {
    "original_path":   "raw/sources/SRC-XXXX/YYYY.md",
    "corrected_path":  "raw/corrected/SRC-XXXX/YYYY.md",
    "hash_original":   "sha256:abc123...",
    "date_ingested":   "YYYY-MM-DD",
    "status":          "processed | stale | unprocessed"
  },

  "contradiction_resolution_flow": [
    {"when": "hash matches", "action": "use existing corrected copy"},
    {"when": "hash mismatch", "action": "flag as stale, proceed to ingest"}
  ],

  "schema_ref_to_agent_rules": "rules/delta_tracking.json"
}
