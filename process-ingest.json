{
  "module": "process_ingest",
  "description": "Поглощение новых данных в wiki — единственный путь: capture → integrate",
  "pre_conditions": [
    {
      "condition": "user_provided_source",
      "action": "START_INGEST"
    },
    {
      "condition": "source_type_unknown",
      "evaluation": [
        {
          "exit_code": 0,
          "action": "CLASSIFY_SOURCE"
        }
      ]
    }
  ],
  "steps": [
    {
      "step_id": "0",
      "name": "guardrails_validation",
      "command": "./scripts/validate-path.sh ${SOURCE_PATH}",
      "evaluation": [
        {
          "exit_code": 0,
          "action": "PROCEED_TO_ANALYSIS"
        },
        {
          "exit_code": 1,
          "stdout_contains": "BLOCKED",
          "action": "HALT_AND_REPORT",
          "message": "Источник в protected zone. Используй capture flow."
        }
      ]
    },
    {
      "step_id": "1",
      "name": "source_analysis",
      "actions": [
        {
          "action": "read_file",
          "path": "${SOURCE_PATH}",
          "purpose": "extract_key_theses"
        },
        {
          "action": "classify_source",
          "types": [
            "entity",
            "concept",
            "notes",
            "meeting",
            "project"
          ]
        },
        {
          "action": "identify_entities_and_concepts",
          "output": "list_of_mentioned_pages"
        },
        {
          "action": "check_for_contradications",
          "reference": "existing_wiki_pages"
        }
      ]
    },
    {
      "step_id": "2",
      "name": "discussion_with_user",
      "actions": [
        {
          "action": "present_summary",
          "content": "key_theses_from_analysis"
        },
        {
          "action": "propose_wiki_pages_to_create_or_update"
        },
        {
          "action": "identify_contradications_for_marking"
        }
      ],
      "evaluation": [
        {
          "user_confirmed": true,
          "action": "PROCEED_TO_INTEGRATION"
        },
        {
          "user_rejected": true,
          "action": "HALT_AND_REPORT",
          "message": "Пользователь отклонил. Ожидаю уточнений."
        }
      ]
    },
    {
      "step_id": "3a",
      "name": "integration_new_page",
      "condition": "source_is_new_entity_or_concept",
      "pre_check": {
        "command": "./scripts/validate-path.sh wiki/${PAGE_PATH}.md",
        "expected_exit_code": 0,
        "on_failure": "HALT_AND_REPORT"
      },
      "actions": [
        {
          "action_type": "create_page",
          "template": "${SOURCE_TYPE}",
          "destination": "wiki/${PAGE_PATH}.md"
        },
        {
          "action": "fill_all_sections",
          "sections": [
            "description",
            "key_characteristics",
            "connections",
            "sources"
          ]
        }
      ],
      "post_check": {
        "command": "./scripts/rebuild-meta.sh",
        "action_on_success": "CONTINUE_TO_LINK_VALIDATION",
        "action_on_failure": "LOG_WARNING_AND_PROCEED"
      },
      "post_operations": [
        {
          "trigger": "page_created",
          "command": "./scripts/post-op-link-scan.sh ${OLD_ORIGINAL_NAME} 50",
          "note": "Scan for cross-references that may need updating. See AGENTS.md#post_operation_link_validation"
        }
      ]
    },
    {
      "step_id": "3b",
      "name": "integration_update_existing_page",
      "condition": "source_updates_existing_entity_or_concept",
      "pre_check": {
        "command": "./scripts/validate-path.sh ${EXISTING_PAGE_PATH}",
        "expected_exit_code": 0,
        "on_failure": "HALT_AND_REPORT"
      },
      "actions": [
        {
          "action": "read_file",
          "path": "${EXISTING_PAGE_PATH}"
        },
        {
          "action": "identify_additions_and_changes"
        },
        {
          "action": "write_update",
          "preserve_old_info": true,
          "append_section": "## Обновлено [date] — новое уточнение"
        }
      ],
      "post_check": {
        "command": "./scripts/rebuild-meta.sh",
        "action_on_success": "CONTINUE_TO_4",
        "action_on_failure": "LOG_WARNING_AND_PROCEED"
      },
      "post_operations": [
        {
          "trigger": "page_updated_with_new_facts",
          "command": "./scripts/post-op-link-scan.sh ${NEW_CONCEPT_OR_ENTITY} 50",
          "note": "Scan for cross-references that may need updating. See AGENTS.md#post_operation_link_validation"
        }
      ]
    },
    {
      "step_id": "3c",
      "name": "cross_link_update",
      "actions": [
        {
          "action": "search_all_wiki_pages_for_mentions",
          "term": "${NEW_ENTITY_CONCEPT_NAME}"
        },
        {
          "action": "add_backlinks_to_each_mentioning_page"
        },
        {
          "action": "mark_orphan_if_no_mentions_found",
          "suggestion": "propose_manual_link_creation"
        }
      ]
    },
    {
      "step_id": "3c",
      "name": "register_source_ingested",
      "description": "После успешного создания/обновления страницы — добавь ID raw-пакета в meta/raw_registry.json, чтобы исключить его из будущих проверок новых источников.",
      "actions": [
        {
          "action": "update_json_file",
          "path": "tracking/raw_registry.json",
          "operation": "append_to_ingested_sources_array",
          "value": "${RAW_PACKAGE_ID}"
        }
      ]
    },
    {
      "step_id": "4",
      "name": "log_registration",
      "pre_check": {
        "command": "./scripts/validate-path.sh wiki/log.md",
        "expected_exit_code": 0,
        "on_failure": "HALT_AND_REPORT"
      },
      "actions": [
        {
          "action": "append_to_log",
          "format": "## [YYYY-MM-DD] ingest | ${SOURCE_NAME}"
        },
        {
          "condition": "multiple_sources",
          "action": "append_batch_entry",
          "format": "## [YYYY-MM-DD] ingest | ${SOURCE_NAME} — несколько файлов"
        }
      ]
    },
    {
      "step_id": "5",
      "name": "index_update",
      "actions": [
        {
          "action": "update_index",
          "category": "${PAGE_TYPE}",
          "entry_format": "* [Название](путь) — Краткое описание."
        }
      ]
    },
    {
      "step_id": "6",
      "name": "post_operation_link_validation",
      "condition": "any_path_change_or_new_page_created",
      "command": "./scripts/post-op-link-scan.sh <old_path_or_pattern> 100",
      "actions": [
        {
          "action": "apply_auto_fix_to_each_broken_link_by_rewriting_to_new_path"
        },
        {
          "condition": "target_does_not_exist",
          "fallback_message": "[!] Broken link: [text](path) — target does not exist. Proposed fix: create page or remove link."
        }
      ],
      "output_handling": {
        "exit_code_0": "no_broken_links — proceed to next step",
        "exit_code_1": "broken_links_found — report with auto-fixable count and apply fixes"
      },
      "schema_ref": "AGENTS.md#post_operation_link_validation"
    }
  ],
  "schema_ref": "AGENTS.md#guardrails",
  "inherits_from": [
    "guardrails",
    "date_convention",
    "logging_templates"
  ],
  "note": "Guardrails are defined in AGENTS.md. This file references them rather than duplicating.",
  "strict_rules": {
    "raw_immutable": "Никогда не редактируй raw/** напрямую. Только capture → integrate.",
    "capture_first_integrate_second": "Сначала сохрани оригинал в raw/, затем создай/обнови wiki-страницу.",
    "meta_protected": "Не трогай meta/** — auto-generated files (registry.json, backlinks.json)."
  },
  "batch_mode": {
    "trigger": "user_specifies_batch_processing",
    "flow": [
      {
        "step": "read_each_source_and_extract_theses"
      },
      {
        "step": "create_or_update_pages_for_all"
      },
      {
        "step": "log_results_and_index"
      }
    ],
    "note": "Этот режим экономит время, но требует доверия к автономным решениям агента."
  }
}