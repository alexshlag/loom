{
  "module": "process_ingest",
  "description": "Ingest new data into wiki - only path: capture - integrate",

  "memory_contract": {
    "rule_ref": "rules/source_transient_ingest.json",
    "rule_id": "STI-V1",
    "when_to_read": "before_processing_any_source", 
    "instruction": "Read source documents one at a time. After extracting entities/facts/concepts into wiki — discard raw content from context. Never hold multiple source texts simultaneously."
  },

  "pre_conditions": [
    {
      "condition": "user_provided_source",
      "action": "START_INGEST"
    },
    {
      "condition": "source_layer_unknown",
      "action": "CLASSIFY_SOURCE"
    }
  ],
  "external_source_policy": {
    "schema_ref": "rules/link_conventions.json#EXT-RES1"
  },
  "cross_process_triggers": [
    {
      "name": "backfill_existing_wiki_references",
      "trigger_condition": "lint_check_12_reports_unprocessed_sources_with_wiki_references",
      "target_process": "process-lint.json check_id=12",
      "schema_ref": "rules/protected_zones.json"
    }
  ],
  "steps": [
    {
      "step_id": "step_1_guardrails",
      "name": "guardrails_validation",
      "description": "Validate source path via guardrails - first step always.",
      "command": "./scripts/validate-path.sh ${SOURCE_PATH}",
      "evaluation": [
        {
          "exit_code": 0,
          "action": "PROCEED_TO_ANALYSIS"
        },
        {
          "exit_code": 1,
          "stdout_contains": "BLOCKED",
          "action": "HALT_AND_REPORT"
        }
      ]
    },
    {
      "step_id": "step_2_delta_check",
      "name": "delta_tracking_hash_check",
      "description": "Hash check - prevents re-ingest of processed sources.",
      "command": "./scripts/rebuild-source-manifest.sh --scan-only",
      "evaluation": [
        {
          "condition": "source_status == processed",
          "action": "HALT_AND_LOG"
        },
        {
          "condition": "source_status == unprocessed OR stale",
          "action": "PROCEED_TO_ANALYSIS"
        }
      ]
    },
    {
      "step_id": "step_3_analysis",
      "name": "source_analysis",
      "description": "Analyze source: read, classify, evidence_grade, entities, contradictions, link repair.",
      "actions": [
        {
          "action": "read_file",
          "path": "${SOURCE_PATH}"
        },
        {
          "action_name": "CLASSIFY_SOURCE"
        },
        {
          "action_name": "extract_evidence_grade"
        },
        {
          "action_name": "identify_entities_and_concepts"
        },
        {
          "action_name": "check_for_contradications"
        },
        {
          "action_name": "raw_source_link_repair",
          "command": "./scripts/raw-link-repair.sh ${SOURCE_PATH} --dry-run"
        }
      ]
    },
    {
      "step_id": "step_3b_aliases_extract",
      "name": "auto_extract_aliases_for_frontmatter",
      "description": "Extract aliases (discoverability synonyms) from title, source content, bilingual variants.",
      "actions": [
        {
          "action_name": "extract_from_title"
        },
        {
          "action_name": "extract_from_source_content"
        },
        {
          "action_name": "apply_tag_guidelines_recommendation",
          "schema_ref": "rules/tag-guidelines.json#aliases_system"
        },
        {
          "action_name": "set_aliases_in_frontmatter"
        }
      ],
      "rules": [
        {
          "rule_id": "ALIAS-SOURCES"
        },
        {
          "rule_id": "ALIAS-MINIMAL",
          "schema_ref": "rules/tag-guidelines.json#aliases_system"
        }
      ]
    },
    {
      "step_id": "step_4_corrected_copy",
      "name": "create_corrected_copy_or_skip",
      "description": "Create corrected copy in raw/corrected/SRC-*/* via scripts/raw-correct.sh.",
      "schema_ref": "rules/protected_zones.json",
      "actions": [
        {
          "action_name": "read_original_and_analyze"
        },
        {
          "action_name": "check_existing_corrected_copy"
        },
        {
          "condition": "corrected_copy_not_exists OR needs_update",
          "action_name": "create_corrected_if_missing"
        }
      ]
    },
    {
      "step_id": "step_4_tag_validation",
      "name": "tag_quality_validation",
      "description": "Validate tags against guidelines — 3-7 domain-specific, no generics. Auto-fix empty/generic.",
      "schema_ref": "rules/tag-guidelines.json",
      "actions": [
        {
          "action_name": "extract_current_tags_from_frontmatter"
        },
        {
          "condition": "tags_are_empty OR tags_contain_generic",
          "action_name": "auto_reject_generic_and_suggest_domain_tags"
        },
        {
          "action_name": "apply_tag_guidelines_recommendation"
        }
      ],
      "rules": [
        {
          "rule_id": "TAG-MINIMUM-3",
          "description": "Minimum 3 tags required"
        },
        {
          "rule_id": "NO-GENERICS",
          "schema_ref": "rules/tag-guidelines.json#policy.prohibited_patterns"
        }
      ]
    },
    {
      "step_id": "step_5_batch_trigger",
      "name": "batch_ingest_trigger",
      "description": "If ≥3 related sources - batch-ingest.sh for clustering.",
      "schema_ref": "rules/batch_ingest_trigger.json",
      "actions": [
        {
          "command": "./scripts/batch-ingest.sh --scan"
        },
        {
          "action_name": "present_clusters_to_user"
        }
      ]
    },
    {
      "step_id": "step_6_discussion",
      "name": "discussion_with_user",
      "description": "Discuss with user: analysis summary, propose create/update pages.",
      "evaluation": [
        {
          "user_confirmed": true,
          "action_name": "DETERMINE_INTEGRATION_TYPE",
          "branching": [
            {
              "condition": "source_is_new_entity_or_concept",
              "target": "step_8a_new_page"
            },
            {
              "condition": "source_updates_existing_entity_or_concept",
              "target": "step_8b_update_page"
            },
            {
              "action_name": "DETERMINE_DOCS_INTEGRATION_TYPE",
              "description": "State-aware routing for docs pages — framework clusters trigger docs workflow. Uses STATE A/B/C logic.",
              "branching": [
                {
                  "condition": "state == no_wiki_docs_exists OR state == generate_overview",
                  "target": "step_8a_new_page",
                  "context": "framework_cluster_detected → wiki/docs/<name>.md with overview structure + docs-index.md"
                },
                {
                  "condition": "state == wiki_docs_orphaned_pages OR audit_required",
                  "target": "step_8b_update_page",
                  "context": "audit orphan pages, propose fixes (add navigation, merge duplicates)"
                },
                {
                  "condition": "state == mature_wiki_docs OR deep_dive_topic",
                  "target": "step_8a_new_page",
                  "context": "deep-dive topic only for existing docs section — suggest merges if overlapping"
                }
              ]
            }
          ]
        },
        {
          "user_rejected": true,
          "action": "HALT_AND_REPORT"
        }
      ]
    },
    {
      "step_id": "step_7_template",
      "name": "template_read_and_section_selection",
      "description": "Agent reads template.json for page structure. For docs pages, selects deep-dive template based on source type (API/CLI/migration/guide) from docs-template.json#template_selection mapping.",
      "actions": [
        {
          "action_name": "read_template"
        },
        {
          "condition": "category == docs",
          "action_name": "select_deep_dive_template_by_source_type",
          "description": "docs-template.json#template_selection.mapping — map source type to specific markdown template (api-reference, cli-commands, migration-guide, deep-dive-guide)",
          "schema_ref": "wiki/templates/docs-template.json#template_selection"
        },
        {
          "action_name": "select_applicable_sections"
        }
      ],
      "rules": [
        {
          "rule_id": "TEMPLATE-READ-V1"
        },
        {
          "rule_id": "FLEXIBLE_ZONES"
        },
        {
          "rule_id": "TEMPLATE_EDIT_WRITE"
        }
      ]
    },
    {
      "step_id": "step_7_crosslink",
      "name": "crosslink_identification_during_ingest",
      "description": "Identify related wiki pages currently in context and create crosslinks immediately. This runs BEFORE page write so links are created during the same agent turn, not deferred to post-checks.",
      "actions": [
        {
          "action_name": "identify_context_related_pages",
          "description": "From current conversation context — list wiki pages that share tags/sources/concepts with new/updated page"
        },
        {
          "command": "./scripts/auto-crosslink.sh --file-list /tmp/crosslink-candidates-${TIMESTAMP}.json '${NEW_PAGE_PATH}' --include-root --min-score 4 --max-results 5 2>/dev/null || true",
          "note": "High-confidence crosslinks (score≥4) added during ingest turn, not deferred"
        },
        {
          "action_name": "add_crosslinks_to_new_page_content",
          "description": "Append identified crosslinks to page content BEFORE writing to disk"
        }
      ],
      "rule": "Crosslinks must be created during ingest turn (same LLM context), not deferred to step_9 post-checks. Reduces orphan pages by preventing disconnected pages."
    },
    {
      "step_id": "step_8a_new_page",
      "name": "integration_new_page",
      "description": "Create NEW wiki page. Syntheses require DR-4 novel inference check.",
      "pre_check": [
        {
          "command": "./scripts/validate-path.sh wiki/${PAGE_PATH}.md"
        },
        {
          "action_name": "check_filename_collision",
          "description": "Scan existing wiki filenames for potential collision with proposed PAGE_PATH. If bare concept name (e.g., 'messenger.md') would collide with project-specific page, enforce project prefix.",
          "rules_ref": "rules/naming_conventions.json#NAMES-CORE-V1",
          "collision_detection_logic": [
            {
              "condition": "proposed_path matches bare concept pattern AND existing_page_with_same_base_name_exists",
              "action": "ENFORCE_PREFIX — rename to <project-slug>-<path>.md"
            },
            {
              "condition": "existing_bare_concept_is_truly_abstract (framework-agnostic)",
              "action": "ALLOW_BARE_NAME — verify no project-specific pages exist under same base"
            }
          ]
        }
      ],
      "syntheses_rule": {
        "rule_id": "DR-4",
        "condition": "page_type == 'synthesis'",
        "action_if_no_novel_inference": "SKIP_SAVE - suggest add to existing page"
      },
      "schema_ref": [
        "rules/structural_requirements.json#FIRST-BLOCK-V1",
        "rules/naming_conventions.json#NAMES-CORE-V1"
      ]
    },
    {
      "step_id": "step_8b_update_page",
      "name": "integration_update_existing_page",
      "description": "Update EXISTING page - preserve old_info, append '## Updated [date]'.",
      "pre_check": [
        {
          "command": "./scripts/validate-path.sh ${EXISTING_PAGE_PATH}"
        }
      ],
      "actions": [
        {
          "action_name": "read_existing_page"
        },
        {
          "action_name": "identify_additions_and_changes"
        },
        {
          "action_name": "write_update",
          "preserve_old_info": true
        }
      ]
    },
    {
      "step_id": "step_9_post_checks",
      "name": "post_integration_checks",
      "step_9_post_checks": {
        "actions": [
          {
            "action_name": "acquire_page_lock"
          },
          {
            "command": "./scripts/rebuild-meta.sh --full"
          },
          {
            "command": "./scripts/text-similarity.sh --scan-all --threshold 90",
            "rule_id": "DR-1_DR-2"
          },
          {
            "command": "./scripts/unified-pass.sh --quiet --skip-meta --skip-crosslinks"
          },
          {
            "command": "./scripts/auto-crosslink.sh '${NEW_PAGE_PATH}' --include-root 2>/dev/null || true"
          },
          {
            "command": "./scripts/rebuild-source-manifest.sh"
          },
          {
            "action_name": "release_page_lock"
          }
        ]
      }
    },
    {
      "step_id": "step_10_register_source",
      "name": "register_source_ingested",
      "description": "Add ID to tracking/raw_registry.json.",
      "actions": [
        {
          "action_name": "update_json_file",
          "path": "tracking/raw_registry.json"
        },
        {
          "action_name": "clear_working_memory_field",
          "field": "new_sources_pending"
        }
      ]
    },
    {
      "step_id": "step_11_log",
      "name": "log_registration",
      "description": "Write to wiki/log.md about completed ingest.",
      "actions": [
        {
          "action_name": "append_to_log",
          "format": "## [YYYY-MM-DD] ingest | ${SOURCE_NAME}"
        }
      ]
    },
    {
      "step_id": "step_12_index",
      "name": "auto_update_index",
      "description": "Rebuild wiki/index.md - last step.",
      "command": "./scripts/rebuild-meta.sh --index-only"
    }
  ],
  "error_handling": {
    "schema_ref": "rules/error_handling.json"
  },
  "schema_evolution": {
    "rule": "Never auto-modify templates - user-approved only, schema-patch requires user approval",
    "schema_ref": "rules/execution_contract.json"
  },
  "context_scope": "transient",
  "memory_hooks": {
    "description": "Memory layer hooks — async, non-blocking. Main process emits events; memory subsystem handles storage/recall/distillation.",
    "hooks": [
      {
        "trigger": "on_start",
        "actions": [
          {
            "action_name": "update_working_memory",
            "command": "echo 'INGEST_START' >> wiki/log.md"
          }
        ]
      },
      {
        "trigger": "on_source_ingested",
        "actions": [
          {
            "action_name": "register_in_registry",
            "command": "./scripts/rebuild-source-manifest.sh || true"
          }
        ]
      },
      {
        "trigger": "on_page_update_completed",
        "actions": [
          {
            "action_name": "update_hot_cache_if_changed",
            "command": "./scripts/memory/hot-cache-update.sh --check-only || true"
          }
        ]
      },
      {
        "trigger": "on_new_page_created",
        "actions": [
          {
            "action_name": "auto_crosslink_new_page",
            "command": "./scripts/auto-crosslink.sh '${NEW_PAGE_PATH}' --include-root 2>/dev/null || true"
          }
        ]
      },
      {
        "trigger": "on_ingest_complete",
        "actions": [
          {
            "action_name": "capture_trajectory_if_nontrivial",
            "command": "./scripts/memory/traj-capture.sh --prompt '<user_query>' --steps '<tool_calls>' --outcome 'success' --complexity 'high'",
            "condition": "new_page_created OR page_updated",
            "schema_ref": "scripts/memory/traj-capture-spec.md"
          }
        ]
      },
      {
        "trigger": "on_complete",
        "actions": [
          {
            "action_name": "update_working_memory",
            "command": "echo 'INGEST_COMPLETE' >> wiki/log.md; echo $(date +%Y-%m-%d) > meta/last-ingest-sync.txt"
          },
          {
            "command": "./scripts/memory/hot-cache-auto-refresh.sh --quiet || true",
            "rule_id": "HOT-WIKI-CHANGES-V1"
          }
        ]
      },
      {
        "trigger": "on_distillation_ready",
        "actions": [
          {
            "action_name": "check_pending_distillations",
            "command": "./scripts/memory/distill.sh --check-undistilled 2>/dev/null || true"
          }
        ]
      },
      {
        "trigger": "on_capture_complete",
        "description": "Auto-distill captured trajectory into wiki skill/case — D2 Phase 20.2",
        "actions": [
          {
            "action_name": "distill_captured_trajectory",
            "command": "./scripts/memory/distill.sh --trajectory '${TRAJECTORY_PATH}' 2>/dev/null || true",
            "condition": "trajectories_path_set",
            "schema_ref": "rules/skill_format.json"
          }
        ]
      }
    ],
    "schema_ref": "scripts/memory/recall-spec.md#process_integration"
  },
  "skill_generation_trigger": {
    "rule_id": "SKILL-AUTOGEN-V1",
    "description": "After task completion: check if pattern is reusable. If new → create wiki/skills/<name>.md from distilled trajectory (with schema_ref to rules/skill_format.json). If existing → link.",
    "when_to_create": [
      "Pattern found in ≥2 tasks",
      "Trajectory captured with high complexity + success outcome"
    ],
    "create_path": "wiki/skills/<pattern_name>.md",
    "schema_ref": "rules/skill_format.json"
  },
  "hook_triggers_in_steps": {
    "step_1_guardrails": {
      "trigger": "on_start",
      "action": "wm_update_on_ingest_start"
    },
    "step_9_post_checks": {
      "triggers": [
        {
          "name": "hot_cache_check",
          "command": "./scripts/memory/hot-cache-update.sh --check-only || true"
        },
        {
          "name": "auto_crosslink",
          "command": "./scripts/auto-crosslink.sh '${NEW_PAGE_PATH}' --include-root 2>/dev/null || true"
        }
      ]
    },
    "step_10_register_source": {
      "trigger": "on_source_ingested",
      "action": "registry_update"
    },
    "step_12_index": {
      "trigger": "on_complete",
      "actions": [
        {
          "name": "wm_sync",
          "command": "echo 'INGEST_COMPLETE' >> wiki/log.md"
        },
        {
          "name": "distillation_check",
          "command": "./scripts/memory/distill.sh --check-undistilled 2>/dev/null || true"
        }
      ]
    }
  }
}