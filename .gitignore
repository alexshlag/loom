# Auto-generated metadata (rebuilt by scripts/rebuild-meta.sh)
meta/**

# Raw sources — immutable, never tracked in git
raw/**

# Tracking state files (only explicit ones are tracked)
tracking/raw_registry.json

# Obsidian local workspace settings (machine-specific)
.obsidian/
.pi/

# OS/editor artifacts
.DS_Store
*.swp
*~
*.pyc
__pycache__/

# Logs — not tracked
logs/*.log

# Similarity cache — large file, regenerated automatically
tracking/similarity_cache.json
.vault-meta/
